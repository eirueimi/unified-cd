{
  "$id": "https://unified-cd/schemas/unified-cd.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "AppSource": {
      "additionalProperties": false,
      "properties": {
        "apiVersion": {
          "const": "unified-cd/v1",
          "type": "string"
        },
        "kind": {
          "const": "AppSource",
          "type": "string"
        },
        "metadata": {
          "$ref": "#/definitions/Metadata"
        },
        "spec": {
          "$ref": "#/definitions/AppSourceSpec"
        }
      },
      "required": [
        "apiVersion",
        "kind",
        "metadata",
        "spec"
      ],
      "type": "object"
    },
    "AppSourceSpec": {
      "additionalProperties": false,
      "properties": {
        "gitCredentialRef": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "repoURL": {
          "type": "string"
        },
        "syncPolicy": {
          "$ref": "#/definitions/AppSyncPolicy"
        },
        "targetRevision": {
          "type": "string"
        }
      },
      "required": [
        "repoURL",
        "targetRevision",
        "path"
      ],
      "type": "object"
    },
    "AppSyncPolicy": {
      "additionalProperties": false,
      "properties": {
        "interval": {
          "type": "string"
        },
        "prune": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "ApprovalStep": {
      "additionalProperties": false,
      "description": "ApprovalStep pauses the run until an authenticated user approves or rejects.\nTimeoutMinutes defaults to 60 (applied at compile time) when zero.",
      "properties": {
        "message": {
          "type": "string"
        },
        "timeoutMinutes": {
          "type": "number"
        }
      },
      "type": "object"
    },
    "CacheStep": {
      "additionalProperties": false,
      "properties": {
        "key": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "restoreKeys": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "ttlDays": {
          "description": "default 30",
          "type": "integer"
        }
      },
      "required": [
        "path",
        "key"
      ],
      "type": "object"
    },
    "CallStep": {
      "additionalProperties": false,
      "properties": {
        "job": {
          "type": "string"
        },
        "with": {
          "additionalProperties": {},
          "type": "object"
        }
      },
      "required": [
        "job"
      ],
      "type": "object"
    },
    "Concurrency": {
      "additionalProperties": false,
      "properties": {
        "mutex": {
          "type": "string"
        },
        "orLocks": {
          "items": {
            "$ref": "#/definitions/OrLock"
          },
          "type": "array"
        },
        "semaphores": {
          "items": {
            "$ref": "#/definitions/Semaphore"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "DownloadArtifactStep": {
      "additionalProperties": false,
      "properties": {
        "destDir": {
          "description": "defaults to the current directory if omitted",
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "ForeachDef": {
      "additionalProperties": false,
      "description": "ForeachDef expands a step into one parallel run per item in the list.\nKey is the variable name accessible in templates as {{ .Foreach.key }}.",
      "properties": {
        "in": {
          "$ref": "#/definitions/ForeachSource"
        },
        "key": {
          "type": "string"
        }
      },
      "required": [
        "key",
        "in"
      ],
      "type": "object"
    },
    "ForeachSource": {
      "additionalProperties": false,
      "description": "ForeachSource is either a literal list (YAML sequence) or a template expression (YAML string).\n\n  in: [prod, staging, dev]                    → Literal\n  in: $envs                                   → Expr (JSON-array param reference)\n  in: \"{{ .Params.envs | split \\\",\\\" }}\"      → Expr (template)\n  in: \"{{ .Steps.list.Outputs.envs | split \\\",\\\" }}\" → Expr (step output reference)",
      "properties": {},
      "type": "object"
    },
    "GitCredential": {
      "additionalProperties": false,
      "description": "GitCredential is the DSL type that defines git credentials for private repositories.",
      "properties": {
        "apiVersion": {
          "const": "unified-cd/v1",
          "type": "string"
        },
        "kind": {
          "const": "GitCredential",
          "type": "string"
        },
        "metadata": {
          "$ref": "#/definitions/Metadata"
        },
        "spec": {
          "$ref": "#/definitions/GitCredentialSpec"
        }
      },
      "required": [
        "apiVersion",
        "kind",
        "metadata",
        "spec"
      ],
      "type": "object"
    },
    "GitCredentialSpec": {
      "additionalProperties": false,
      "description": "GitCredentialSpec is the spec section of GitCredential.",
      "properties": {
        "host": {
          "description": "hostname to use these credentials for (e.g. github.com)",
          "type": "string"
        },
        "secretRef": {
          "description": "name of the StoredSecret that holds the value",
          "type": "string"
        },
        "type": {
          "description": "authentication type",
          "enum": [
            "token",
            "sshKey"
          ],
          "type": "string"
        }
      },
      "required": [
        "host",
        "type",
        "secretRef"
      ],
      "type": "object"
    },
    "Input": {
      "additionalProperties": false,
      "properties": {
        "default": {},
        "description": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "type": {
          "enum": [
            "string",
            "bool",
            "int",
            "array"
          ],
          "type": "string"
        }
      },
      "required": [
        "name",
        "type"
      ],
      "type": "object"
    },
    "Job": {
      "additionalProperties": false,
      "properties": {
        "apiVersion": {
          "const": "unified-cd/v1",
          "type": "string"
        },
        "kind": {
          "const": "Job",
          "type": "string"
        },
        "metadata": {
          "$ref": "#/definitions/Metadata"
        },
        "spec": {
          "$ref": "#/definitions/Spec"
        }
      },
      "required": [
        "apiVersion",
        "kind",
        "metadata",
        "spec"
      ],
      "type": "object"
    },
    "Metadata": {
      "additionalProperties": false,
      "properties": {
        "labels": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "name": {
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "OrLock": {
      "additionalProperties": false,
      "description": "OrLock acquires exactly one candidate from In — whichever is free — instead of\nrequiring all of them like Semaphores does. The acquired candidate value is\nexposed to the Job's steps as a synthesized parameter named\nstrings.ToUpper(Name)+\"_LOCK_VALUE\" (e.g. Name \"env\" -\u003e \"ENV_LOCK_VALUE\"),\nreadable via {{ .Params.ENV_LOCK_VALUE }}.",
      "properties": {
        "in": {
          "$ref": "#/definitions/ForeachSource"
        },
        "name": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "in"
      ],
      "type": "object"
    },
    "Output": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "type": {
          "description": "\"string\", \"bool\", \"int\", \"artifact\"",
          "enum": [
            "string",
            "bool",
            "int",
            "artifact"
          ],
          "type": "string"
        }
      },
      "required": [
        "name",
        "type"
      ],
      "type": "object"
    },
    "Params": {
      "additionalProperties": false,
      "properties": {
        "inputs": {
          "items": {
            "$ref": "#/definitions/Input"
          },
          "type": "array"
        },
        "outputs": {
          "items": {
            "$ref": "#/definitions/Output"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "PodSpecPatch": {
      "additionalProperties": false,
      "properties": {
        "containers": {
          "items": {
            "additionalProperties": {},
            "type": "object"
          },
          "type": "array"
        },
        "volumes": {
          "items": {
            "additionalProperties": {},
            "type": "object"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "PodTemplate": {
      "additionalProperties": false,
      "properties": {
        "cleanWorkspace": {
          "type": "boolean"
        },
        "name": {
          "type": "string"
        },
        "override": {
          "$ref": "#/definitions/PodSpecPatch"
        },
        "reuse": {
          "type": "boolean"
        },
        "spec": {
          "additionalProperties": {},
          "type": "object"
        },
        "workspace": {
          "$ref": "#/definitions/WorkspaceConfig"
        }
      },
      "type": "object"
    },
    "PostStep": {
      "additionalProperties": false,
      "description": "PostStep defines cleanup/post-processing to run after a step completes.\nExecuted in LIFO order after RunDAG completes.",
      "properties": {
        "env": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "run": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "Schedule": {
      "additionalProperties": false,
      "description": "Schedule is the DSL type for a cron schedule trigger.",
      "properties": {
        "apiVersion": {
          "const": "unified-cd/v1",
          "type": "string"
        },
        "kind": {
          "const": "Schedule",
          "type": "string"
        },
        "metadata": {
          "$ref": "#/definitions/Metadata"
        },
        "spec": {
          "$ref": "#/definitions/ScheduleSpec"
        }
      },
      "required": [
        "apiVersion",
        "kind",
        "metadata",
        "spec"
      ],
      "type": "object"
    },
    "ScheduleSpec": {
      "additionalProperties": false,
      "description": "ScheduleSpec is the spec section of Schedule.",
      "properties": {
        "cron": {
          "type": "string"
        },
        "job": {
          "type": "string"
        },
        "params": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        }
      },
      "required": [
        "cron",
        "job"
      ],
      "type": "object"
    },
    "Semaphore": {
      "additionalProperties": false,
      "properties": {
        "capacity": {
          "type": "integer"
        },
        "pool": {
          "type": "string"
        }
      },
      "required": [
        "pool",
        "capacity"
      ],
      "type": "object"
    },
    "Spec": {
      "additionalProperties": false,
      "properties": {
        "agentSelector": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "concurrency": {
          "$ref": "#/definitions/Concurrency"
        },
        "finally": {
          "description": "Finally runs after the main DAG completes, on success, failure, or\ncancellation. Same structure as Steps. A finally step's `if:` defaults to\nalways-run; use if: failure()/success() to filter. A finally step that\nfails marks the run Failed (after all finally steps run).",
          "items": {
            "$ref": "#/definitions/StepEntry"
          },
          "type": "array"
        },
        "params": {
          "$ref": "#/definitions/Params"
        },
        "podTemplate": {
          "$ref": "#/definitions/PodTemplate"
        },
        "steps": {
          "description": "Steps is the main DAG of steps to execute.\n(failFast was removed — all started steps run to completion.)",
          "items": {
            "$ref": "#/definitions/StepEntry"
          },
          "type": "array"
        },
        "timeoutMinutes": {
          "type": "number"
        }
      },
      "required": [
        "params",
        "steps"
      ],
      "type": "object"
    },
    "Step": {
      "additionalProperties": false,
      "description": "Step is a concrete step. Used inside parallel: blocks and as the body of a StepEntry.",
      "properties": {
        "approval": {
          "$ref": "#/definitions/ApprovalStep"
        },
        "cache": {
          "$ref": "#/definitions/CacheStep"
        },
        "call": {
          "$ref": "#/definitions/CallStep"
        },
        "container": {
          "type": "string"
        },
        "continueOnError": {
          "type": "boolean"
        },
        "downloadArtifact": {
          "$ref": "#/definitions/DownloadArtifactStep"
        },
        "env": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "foreach": {
          "$ref": "#/definitions/ForeachDef"
        },
        "if": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "outputs": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "post": {
          "$ref": "#/definitions/PostStep"
        },
        "run": {
          "type": "string"
        },
        "timeoutMinutes": {
          "type": "number"
        },
        "uploadArtifact": {
          "$ref": "#/definitions/UploadArtifactStep"
        },
        "uses": {
          "$ref": "#/definitions/UsesStep"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "StepEntry": {
      "additionalProperties": false,
      "description": "StepEntry is either a concrete step (Name is set) or a parallel group (Parallel is set).\nThe two forms are mutually exclusive; Validate enforces this.",
      "properties": {
        "approval": {
          "$ref": "#/definitions/ApprovalStep"
        },
        "cache": {
          "$ref": "#/definitions/CacheStep"
        },
        "call": {
          "$ref": "#/definitions/CallStep"
        },
        "container": {
          "type": "string"
        },
        "continueOnError": {
          "type": "boolean"
        },
        "downloadArtifact": {
          "$ref": "#/definitions/DownloadArtifactStep"
        },
        "env": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "foreach": {
          "$ref": "#/definitions/ForeachDef"
        },
        "if": {
          "type": "string"
        },
        "name": {
          "description": "Concrete step fields (identical to Step, minus Needs)",
          "type": "string"
        },
        "outputs": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "parallel": {
          "description": "Parallel group (mutually exclusive with all concrete step fields above)",
          "items": {
            "$ref": "#/definitions/Step"
          },
          "type": "array"
        },
        "post": {
          "$ref": "#/definitions/PostStep"
        },
        "run": {
          "type": "string"
        },
        "timeoutMinutes": {
          "type": "number"
        },
        "uploadArtifact": {
          "$ref": "#/definitions/UploadArtifactStep"
        },
        "uses": {
          "$ref": "#/definitions/UsesStep"
        }
      },
      "type": "object"
    },
    "UploadArtifactStep": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "path": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "path"
      ],
      "type": "object"
    },
    "UsesStep": {
      "additionalProperties": false,
      "description": "UsesStep inlines a git-template job's steps directly into the current run.\nJob must be a git:// URI; unlike CallStep, it never references a registered job name.",
      "properties": {
        "job": {
          "type": "string"
        },
        "with": {
          "additionalProperties": {},
          "type": "object"
        }
      },
      "required": [
        "job"
      ],
      "type": "object"
    },
    "WebhookAuth": {
      "additionalProperties": false,
      "properties": {
        "secretRef": {
          "type": "string"
        },
        "type": {
          "description": "none | hmac-sha256 | github (X-Hub-Signature-256)",
          "enum": [
            "none",
            "hmac-sha256",
            "github"
          ],
          "type": "string"
        }
      },
      "required": [
        "type"
      ],
      "type": "object"
    },
    "WebhookReceiver": {
      "additionalProperties": false,
      "description": "WebhookReceiver is the DSL type for webhook receiver configuration.",
      "properties": {
        "apiVersion": {
          "const": "unified-cd/v1",
          "type": "string"
        },
        "kind": {
          "const": "WebhookReceiver",
          "type": "string"
        },
        "metadata": {
          "$ref": "#/definitions/Metadata"
        },
        "spec": {
          "$ref": "#/definitions/WebhookReceiverSpec"
        }
      },
      "required": [
        "apiVersion",
        "kind",
        "metadata",
        "spec"
      ],
      "type": "object"
    },
    "WebhookReceiverSpec": {
      "additionalProperties": false,
      "properties": {
        "auth": {
          "$ref": "#/definitions/WebhookAuth"
        },
        "filters": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "paramsMapping": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "trigger": {
          "$ref": "#/definitions/WebhookTrigger"
        }
      },
      "required": [
        "trigger",
        "auth"
      ],
      "type": "object"
    },
    "WebhookTrigger": {
      "additionalProperties": false,
      "properties": {
        "job": {
          "type": "string"
        }
      },
      "required": [
        "job"
      ],
      "type": "object"
    },
    "WorkspaceConfig": {
      "additionalProperties": false,
      "properties": {
        "mountPath": {
          "type": "string"
        },
        "pvc": {
          "$ref": "#/definitions/WorkspacePVC"
        }
      },
      "type": "object"
    },
    "WorkspacePVC": {
      "additionalProperties": false,
      "properties": {
        "accessMode": {
          "enum": [
            "ReadWriteOnce",
            "ReadOnlyMany",
            "ReadWriteMany"
          ],
          "type": "string"
        },
        "claimName": {
          "type": "string"
        },
        "storageClassName": {
          "type": "string"
        },
        "storageRequest": {
          "type": "string"
        }
      },
      "type": "object"
    }
  },
  "description": "unified-cd DSL schema — generated from internal/dsl/*_types.go",
  "oneOf": [
    {
      "$ref": "#/definitions/Job"
    },
    {
      "$ref": "#/definitions/Schedule"
    },
    {
      "$ref": "#/definitions/WebhookReceiver"
    },
    {
      "$ref": "#/definitions/AppSource"
    },
    {
      "$ref": "#/definitions/GitCredential"
    }
  ],
  "title": "unified-cd"
}
