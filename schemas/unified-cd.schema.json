{
  "$id": "https://unified-cd/schemas/unified-cd.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "AppSource": {
      "additionalProperties": false,
      "properties": {
        "apiVersion": {
          "const": "unified-cd/v1",
          "type": "string"
        },
        "kind": {
          "const": "AppSource",
          "type": "string"
        },
        "metadata": {
          "$ref": "#/definitions/Metadata"
        },
        "spec": {
          "$ref": "#/definitions/AppSourceSpec"
        }
      },
      "required": [
        "apiVersion",
        "kind",
        "metadata",
        "spec"
      ],
      "type": "object"
    },
    "AppSourceSpec": {
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string"
        },
        "repoURL": {
          "type": "string"
        },
        "syncPolicy": {
          "$ref": "#/definitions/AppSyncPolicy"
        },
        "targetRevision": {
          "type": "string"
        }
      },
      "required": [
        "repoURL",
        "targetRevision",
        "path"
      ],
      "type": "object"
    },
    "AppSyncPolicy": {
      "additionalProperties": false,
      "properties": {
        "allowManualOverride": {
          "description": "AllowManualOverride disables the managed-resource write guard for\nresources managed by this AppSource (direct apply/delete is allowed).",
          "type": "boolean"
        },
        "interval": {
          "type": "string"
        },
        "prune": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "ApprovalStep": {
      "additionalProperties": false,
      "description": "ApprovalStep pauses the run until an authenticated user approves or rejects.\nTimeoutMinutes defaults to 60 (applied at compile time) when zero.",
      "properties": {
        "message": {
          "type": "string"
        },
        "timeoutMinutes": {
          "type": "number"
        }
      },
      "type": "object"
    },
    "CacheStep": {
      "additionalProperties": false,
      "properties": {
        "key": {
          "description": "cache key; supports template expansion",
          "type": "string"
        },
        "path": {
          "description": "directory to cache; supports template expansion",
          "type": "string"
        },
        "restoreKeys": {
          "description": "fallback key prefixes; support template expansion",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "ttlDays": {
          "description": "default 30",
          "type": "integer"
        }
      },
      "required": [
        "path",
        "key"
      ],
      "type": "object"
    },
    "CallStep": {
      "additionalProperties": false,
      "properties": {
        "job": {
          "type": "string"
        },
        "with": {
          "additionalProperties": {},
          "type": "object"
        }
      },
      "required": [
        "job"
      ],
      "type": "object"
    },
    "Concurrency": {
      "additionalProperties": false,
      "properties": {
        "mutex": {
          "type": "string"
        },
        "orLocks": {
          "items": {
            "$ref": "#/definitions/OrLock"
          },
          "type": "array"
        },
        "semaphores": {
          "items": {
            "$ref": "#/definitions/Semaphore"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "DownloadArtifactStep": {
      "additionalProperties": false,
      "properties": {
        "destDir": {
          "description": "defaults to the current directory if omitted",
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "ForeachDef": {
      "additionalProperties": false,
      "description": "ForeachDef expands a step into one parallel run per item in the list.\nKey is the variable name accessible in templates as {{ .Foreach.key }}.",
      "properties": {
        "in": {
          "$ref": "#/definitions/ForeachSource"
        },
        "key": {
          "type": "string"
        }
      },
      "required": [
        "key",
        "in"
      ],
      "type": "object"
    },
    "ForeachSource": {
      "description": "ForeachSource is either a literal list (YAML sequence) or a template expression (YAML string).\n\n  in: [prod, staging, dev]                    → Literal\n  in: $envs                                   → Expr (JSON-array param reference)\n  in: \"{{ .Params.envs | split \\\",\\\" }}\"      → Expr (template)\n  in: \"{{ .Steps.list.Outputs.envs | split \\\",\\\" }}\" → Expr (step output reference)",
      "oneOf": [
        {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        {
          "type": "string"
        }
      ]
    },
    "GitCredential": {
      "additionalProperties": false,
      "description": "GitCredential is the DSL type that defines git credentials for private repositories.",
      "properties": {
        "apiVersion": {
          "const": "unified-cd/v1",
          "type": "string"
        },
        "kind": {
          "const": "GitCredential",
          "type": "string"
        },
        "metadata": {
          "$ref": "#/definitions/Metadata"
        },
        "spec": {
          "$ref": "#/definitions/GitCredentialSpec"
        }
      },
      "required": [
        "apiVersion",
        "kind",
        "metadata",
        "spec"
      ],
      "type": "object"
    },
    "GitCredentialSpec": {
      "additionalProperties": false,
      "description": "GitCredentialSpec is the spec section of GitCredential.",
      "properties": {
        "host": {
          "description": "hostname to use these credentials for (e.g. github.com)",
          "type": "string"
        },
        "secretRef": {
          "description": "name of the StoredSecret that holds the value",
          "type": "string"
        },
        "type": {
          "description": "authentication type",
          "enum": [
            "token",
            "sshKey"
          ],
          "type": "string"
        }
      },
      "required": [
        "host",
        "type",
        "secretRef"
      ],
      "type": "object"
    },
    "Input": {
      "additionalProperties": false,
      "properties": {
        "default": {},
        "description": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "type": {
          "enum": [
            "string",
            "bool",
            "int",
            "array"
          ],
          "type": "string"
        }
      },
      "required": [
        "name",
        "type"
      ],
      "type": "object"
    },
    "Job": {
      "additionalProperties": false,
      "properties": {
        "apiVersion": {
          "const": "unified-cd/v1",
          "type": "string"
        },
        "kind": {
          "const": "Job",
          "type": "string"
        },
        "metadata": {
          "$ref": "#/definitions/Metadata"
        },
        "spec": {
          "$ref": "#/definitions/Spec"
        }
      },
      "required": [
        "apiVersion",
        "kind",
        "metadata",
        "spec"
      ],
      "type": "object"
    },
    "MatrixDef": {
      "additionalProperties": {
        "$ref": "#/definitions/ForeachSource"
      },
      "description": "MatrixDef expands a step into one copy per combination of dimension values\n(cartesian product minus exclude entries). Dimensions preserve YAML\ndeclaration order; the combination key joins values with \"/\" in that order\n(e.g. \"linux/amd64\").",
      "properties": {
        "exclude": {
          "items": {
            "additionalProperties": {
              "type": "string"
            },
            "type": "object"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "MatrixDimension": {
      "additionalProperties": false,
      "properties": {},
      "type": "object"
    },
    "Metadata": {
      "additionalProperties": false,
      "properties": {
        "annotations": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "labels": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "name": {
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "OrLock": {
      "additionalProperties": false,
      "description": "OrLock acquires exactly one candidate from In — whichever is free — instead of\nrequiring all of them like Semaphores does. The acquired candidate value is\nexposed to the Job's steps as a synthesized parameter named\nstrings.ToUpper(Name)+\"_LOCK_VALUE\" (e.g. Name \"env\" -\u003e \"ENV_LOCK_VALUE\"),\nreadable via {{ .Params.ENV_LOCK_VALUE }}.",
      "properties": {
        "in": {
          "$ref": "#/definitions/ForeachSource"
        },
        "name": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "in"
      ],
      "type": "object"
    },
    "Output": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "type": {
          "description": "\"string\", \"bool\", \"int\", \"artifact\"",
          "enum": [
            "string",
            "bool",
            "int",
            "artifact"
          ],
          "type": "string"
        }
      },
      "required": [
        "name",
        "type"
      ],
      "type": "object"
    },
    "Params": {
      "additionalProperties": false,
      "properties": {
        "inputs": {
          "items": {
            "$ref": "#/definitions/Input"
          },
          "type": "array"
        },
        "outputs": {
          "items": {
            "$ref": "#/definitions/Output"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "PodSpecPatch": {
      "additionalProperties": false,
      "properties": {
        "containers": {
          "items": {
            "additionalProperties": {},
            "type": "object"
          },
          "type": "array"
        },
        "volumes": {
          "items": {
            "additionalProperties": {},
            "type": "object"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "PodTemplate": {
      "additionalProperties": false,
      "properties": {
        "cleanWorkspace": {
          "type": "boolean"
        },
        "name": {
          "type": "string"
        },
        "override": {
          "$ref": "#/definitions/PodSpecPatch"
        },
        "reuse": {
          "type": "boolean"
        },
        "spec": {
          "additionalProperties": {},
          "type": "object"
        },
        "workspace": {
          "$ref": "#/definitions/WorkspaceConfig"
        }
      },
      "type": "object"
    },
    "PostStep": {
      "additionalProperties": false,
      "description": "PostStep defines cleanup/post-processing to run after a step completes.\nExecuted in LIFO order after RunDAG completes.",
      "properties": {
        "env": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "run": {
          "type": "string"
        },
        "shell": {
          "description": "Shell overrides the interpreter argv for this post hook. When absent,\nthe hook inherits its owning step's effective shell. The override\nexists because inheritance alone breaks down for non-shell\ninterpreters: a step running under shell: [python3, -c] with a\nshell-script cleanup hook needs post: {shell: [sh, -c], run: ...} to\nbe expressible at all.",
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "ResourceList": {
      "additionalProperties": false,
      "description": "ResourceList is a cpu/memory pair using Kubernetes quantity strings\n(e.g. \"500m\", \"1\", \"256Mi\", \"1Gi\").",
      "properties": {
        "cpu": {
          "type": "string"
        },
        "memory": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "ResourceSpec": {
      "additionalProperties": false,
      "description": "ResourceSpec declares CPU/memory requests and limits for a runsIn.image step.",
      "properties": {
        "limits": {
          "$ref": "#/definitions/ResourceList"
        },
        "requests": {
          "$ref": "#/definitions/ResourceList"
        }
      },
      "type": "object"
    },
    "RetrySpec": {
      "additionalProperties": false,
      "description": "RetrySpec configures automatic re-runs of a failing run: step.",
      "properties": {
        "attempts": {
          "description": "Attempts is the total number of tries (1 = no retry). Must be \u003e= 1.",
          "type": "integer"
        },
        "backoff": {
          "description": "Backoff is a fixed wait between tries as a Go duration (e.g. \"30s\").\nEmpty means 0 (immediate retry).",
          "type": "string"
        }
      },
      "required": [
        "attempts"
      ],
      "type": "object"
    },
    "RunsIn": {
      "additionalProperties": false,
      "description": "RunsIn declares the execution context for a uses: template entry. It is no\nlonger legal on a plain step (step-level runsIn: was removed; the flat\ncontainer: field is the canonical way to pin a plain step to a podTemplate\ncontainer). On a uses: entry, only the image form is accepted: it declares\nthat the whole inlined template runs in one fresh isolated scope built from\nthis image (host: `\u003crt\u003e run`; k8s: a throwaway pod). No workspace is shared\n— pass inputs via with:/env, return outputs via outputs:/stdout.\nrunsIn.container on a uses: entry is rejected; set container: on the\ntemplate's own steps instead.",
      "properties": {
        "container": {
          "type": "string"
        },
        "image": {
          "type": "string"
        },
        "resources": {
          "$ref": "#/definitions/ResourceSpec"
        }
      },
      "type": "object"
    },
    "Schedule": {
      "additionalProperties": false,
      "description": "Schedule is the DSL type for a cron schedule trigger.",
      "properties": {
        "apiVersion": {
          "const": "unified-cd/v1",
          "type": "string"
        },
        "kind": {
          "const": "Schedule",
          "type": "string"
        },
        "metadata": {
          "$ref": "#/definitions/Metadata"
        },
        "spec": {
          "$ref": "#/definitions/ScheduleSpec"
        }
      },
      "required": [
        "apiVersion",
        "kind",
        "metadata",
        "spec"
      ],
      "type": "object"
    },
    "ScheduleSpec": {
      "additionalProperties": false,
      "description": "ScheduleSpec is the spec section of Schedule.",
      "properties": {
        "cron": {
          "type": "string"
        },
        "job": {
          "type": "string"
        },
        "params": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        }
      },
      "required": [
        "cron",
        "job"
      ],
      "type": "object"
    },
    "Semaphore": {
      "additionalProperties": false,
      "properties": {
        "capacity": {
          "type": "integer"
        },
        "pool": {
          "type": "string"
        }
      },
      "required": [
        "pool",
        "capacity"
      ],
      "type": "object"
    },
    "Spec": {
      "additionalProperties": false,
      "properties": {
        "agentSelector": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "concurrency": {
          "$ref": "#/definitions/Concurrency"
        },
        "description": {
          "description": "Description is a human-readable summary of the job, shown in the WebUI.",
          "type": "string"
        },
        "finally": {
          "description": "Finally runs after the main DAG completes, on success, failure, or\ncancellation. Same structure as Steps. A finally step's `if:` defaults to\nalways-run; use if: failure()/success() to filter. A finally step that\nfails marks the run Failed (after all finally steps run).",
          "items": {
            "$ref": "#/definitions/StepEntry"
          },
          "type": "array"
        },
        "native": {
          "description": "Native opts the whole job into host-process execution (no claim pod,\nno podTemplate, no container: steps). Host agents only; the default\n(false) is the isolated pod model on both backends.",
          "type": "boolean"
        },
        "params": {
          "$ref": "#/definitions/Params"
        },
        "podTemplate": {
          "$ref": "#/definitions/PodTemplate"
        },
        "shell": {
          "description": "Shell overrides the default interpreter argv for every step in this\njob that does not declare its own step-level shell:. Array-only (no\nscalar shorthand); the run: script is appended as the final argv\nelement. See Step.Shell for the full resolution priority.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "steps": {
          "description": "Steps is the main DAG of steps to execute.\n(failFast was removed — all started steps run to completion.)",
          "items": {
            "$ref": "#/definitions/StepEntry"
          },
          "type": "array"
        },
        "timeoutMinutes": {
          "type": "number"
        }
      },
      "required": [
        "params",
        "steps"
      ],
      "type": "object"
    },
    "Step": {
      "additionalProperties": false,
      "description": "Step is a concrete step. Used inside parallel: blocks and as the body of a StepEntry.",
      "properties": {
        "approval": {
          "$ref": "#/definitions/ApprovalStep"
        },
        "cache": {
          "$ref": "#/definitions/CacheStep"
        },
        "call": {
          "$ref": "#/definitions/CallStep"
        },
        "container": {
          "type": "string"
        },
        "continueOnError": {
          "type": "boolean"
        },
        "downloadArtifact": {
          "$ref": "#/definitions/DownloadArtifactStep"
        },
        "env": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "foreach": {
          "$ref": "#/definitions/ForeachDef"
        },
        "if": {
          "type": "string"
        },
        "matrix": {
          "$ref": "#/definitions/MatrixDef"
        },
        "name": {
          "type": "string"
        },
        "outputs": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "post": {
          "$ref": "#/definitions/PostStep"
        },
        "retry": {
          "$ref": "#/definitions/RetrySpec"
        },
        "run": {
          "type": "string"
        },
        "runsIn": {
          "$ref": "#/definitions/RunsIn"
        },
        "scopeID": {
          "description": "Scope tagging: set by inline expansion when a uses-level runsIn.image\nmakes the whole template one isolated scope. Steps sharing ScopeID run\nin one environment. Not user-authored.",
          "type": "string"
        },
        "scopeImage": {
          "type": "string"
        },
        "shell": {
          "description": "Shell overrides the effective interpreter argv for this step. Array\nform only (v1): e.g. [bash, -lc] or [python3, -c]; the run: script is\nappended as the final argv element. Resolution priority (most specific\nwins): step.shell \u003e a uses: template's own declared shell \u003e spec.shell\n(job-level) \u003e system default. Steps inside parallel: and finally:\ncount as steps for this purpose.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "timeoutMinutes": {
          "type": "number"
        },
        "uploadArtifact": {
          "$ref": "#/definitions/UploadArtifactStep"
        },
        "uses": {
          "$ref": "#/definitions/UsesStep"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "StepEntry": {
      "additionalProperties": false,
      "description": "StepEntry is either a concrete step (Name is set) or a parallel group (Parallel is set).\nThe two forms are mutually exclusive; Validate enforces this.",
      "properties": {
        "approval": {
          "$ref": "#/definitions/ApprovalStep"
        },
        "cache": {
          "$ref": "#/definitions/CacheStep"
        },
        "call": {
          "$ref": "#/definitions/CallStep"
        },
        "container": {
          "type": "string"
        },
        "continueOnError": {
          "type": "boolean"
        },
        "downloadArtifact": {
          "$ref": "#/definitions/DownloadArtifactStep"
        },
        "env": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "foreach": {
          "$ref": "#/definitions/ForeachDef"
        },
        "if": {
          "type": "string"
        },
        "matrix": {
          "$ref": "#/definitions/MatrixDef"
        },
        "name": {
          "description": "Concrete step fields (identical to Step, minus Needs)",
          "type": "string"
        },
        "outputs": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "parallel": {
          "description": "Parallel group (mutually exclusive with all concrete step fields above)",
          "items": {
            "$ref": "#/definitions/Step"
          },
          "type": "array"
        },
        "post": {
          "$ref": "#/definitions/PostStep"
        },
        "retry": {
          "$ref": "#/definitions/RetrySpec"
        },
        "run": {
          "type": "string"
        },
        "runsIn": {
          "$ref": "#/definitions/RunsIn"
        },
        "scopeID": {
          "description": "Scope tagging: set by inline expansion when a uses-level runsIn.image\nmakes the whole template one isolated scope. Steps sharing ScopeID run\nin one environment. Not user-authored.",
          "type": "string"
        },
        "scopeImage": {
          "type": "string"
        },
        "shell": {
          "description": "Shell overrides the effective interpreter argv for this step. See\nStep.Shell for the full resolution priority.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "timeoutMinutes": {
          "type": "number"
        },
        "uploadArtifact": {
          "$ref": "#/definitions/UploadArtifactStep"
        },
        "uses": {
          "$ref": "#/definitions/UsesStep"
        }
      },
      "type": "object"
    },
    "UploadArtifactStep": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "path": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "path"
      ],
      "type": "object"
    },
    "UsesStep": {
      "additionalProperties": false,
      "description": "UsesStep inlines a git-template job's steps directly into the current run.\nJob must be a git:// URI; unlike CallStep, it never references a registered job name.",
      "properties": {
        "job": {
          "type": "string"
        },
        "with": {
          "additionalProperties": {},
          "type": "object"
        }
      },
      "required": [
        "job"
      ],
      "type": "object"
    },
    "WebhookAuth": {
      "additionalProperties": false,
      "properties": {
        "header": {
          "description": "token type only: header to compare (default X-Gitlab-Token)",
          "type": "string"
        },
        "secretRef": {
          "type": "string"
        },
        "type": {
          "description": "none | hmac-sha256 | github | token",
          "enum": [
            "none",
            "hmac-sha256",
            "github",
            "token"
          ],
          "type": "string"
        }
      },
      "required": [
        "type"
      ],
      "type": "object"
    },
    "WebhookReceiver": {
      "additionalProperties": false,
      "description": "WebhookReceiver is the DSL type for webhook receiver configuration.",
      "properties": {
        "apiVersion": {
          "const": "unified-cd/v1",
          "type": "string"
        },
        "kind": {
          "const": "WebhookReceiver",
          "type": "string"
        },
        "metadata": {
          "$ref": "#/definitions/Metadata"
        },
        "spec": {
          "$ref": "#/definitions/WebhookReceiverSpec"
        }
      },
      "required": [
        "apiVersion",
        "kind",
        "metadata",
        "spec"
      ],
      "type": "object"
    },
    "WebhookReceiverSpec": {
      "additionalProperties": false,
