# ============================================================
# unified-cd environment variables
# cp .env.example .env  then edit as needed
# ============================================================

# ---- Auth ----
# Admin token for API / CLI access (change in production!)
UNIFIED_TOKEN=dev-token-change-me

# 32-byte hex key for secret encryption (run once, keep safe).
# If empty, master generates an ephemeral key — secrets are lost on restart.
# Generate: openssl rand -hex 32
UNIFIED_MASTER_KEY=

# ---- Database ----
# Set automatically by docker-compose; override for external DB.
# UNIFIED_DB_DSN=postgres://unified:unified@localhost:5432/unified?sslmode=disable

# ---- Object Store (Garage / S3) ----
# Set automatically by docker-compose; override for AWS S3 / GCS.
# UNIFIED_S3_ENDPOINT=s3.amazonaws.com
# UNIFIED_S3_BUCKET=my-unified-cd-logs
# UNIFIED_S3_KEY=AKIAIOSFODNN7EXAMPLE
# UNIFIED_S3_SECRET=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# ---- OIDC (optional) ----
# UNIFIED_OIDC_ISSUER=https://accounts.google.com
# UNIFIED_OIDC_CLIENT_ID=your-client-id
