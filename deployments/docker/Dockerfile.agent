FROM golang:1.26-alpine AS builder
WORKDIR /src
COPY go.mod go.sum ./
COPY vendor/ vendor/
COPY . .
RUN CGO_ENABLED=0 GOFLAGS=-mod=vendor go build -trimpath -o /unified-agent ./cmd/agent

FROM alpine:3.20
RUN apk add --no-cache bash git ca-certificates
COPY --from=builder /unified-agent /usr/local/bin/unified-agent
ENTRYPOINT ["/usr/local/bin/unified-agent"]
