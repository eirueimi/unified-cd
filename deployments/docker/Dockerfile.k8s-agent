FROM golang:1.26-alpine AS builder
WORKDIR /src
COPY go.mod go.sum ./
COPY vendor/ vendor/
COPY . .
RUN CGO_ENABLED=0 GOFLAGS=-mod=vendor go build -trimpath -o /unified-k8s-agent ./cmd/k8s-agent

FROM alpine:3.20
RUN apk add --no-cache ca-certificates
COPY --from=builder /unified-k8s-agent /usr/local/bin/unified-k8s-agent
ENTRYPOINT ["/usr/local/bin/unified-k8s-agent"]
